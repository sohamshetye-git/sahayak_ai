# Frontend Production Environment Variables
# These variables are embedded into the static build at build time

# Backend API URL - Update this with your actual API Gateway URL
NEXT_PUBLIC_API_URL=https://your-api-gateway-id.execute-api.ap-south-1.amazonaws.com/prod

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Feature Flags
# NEXT_PUBLIC_ENABLE_VOICE=true
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
