# ============================================
# SAHAYAK AI - AWS PRODUCTION DEPLOYMENT
# Optimized for Heavy Workload & High Availability
# ============================================

NODE_ENV=production
ENVIRONMENT=production
PORT=3001

# ============================================
# AWS CORE CONFIGURATION
# ============================================
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-account-id-here
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ============================================
# DATABASE - AWS RDS POSTGRESQL (Multi-AZ)
# High-availability relational database
# ============================================
DB_HOST=sahayak-db.cluster-xxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=sahayak_production
DB_USER=admin
DB_PASSWORD=your_rds_password_here
DB_MAX_CONNECTIONS=100
DB_SSL=true
RDS_HOST=sahayak-db.cluster-xxxxx.ap-south-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=sahayak_production
RDS_USER=admin
RDS_PASSWORD=your_rds_password_here

# ============================================
# DATABASE - AWS DYNAMODB (Primary NoSQL)
# Serverless, auto-scaling database
# ============================================
DYNAMODB_SCHEMES_TABLE=sahayak-schemes-prod
DYNAMODB_APPLICATIONS_TABLE=sahayak-applications-prod
DYNAMODB_CHAT_SESSIONS_TABLE=sahayak-chat-sessions-prod
DYNAMODB_SERVICE_CENTERS_TABLE=sahayak-service-centers-prod

# ============================================
# CACHE - AWS ELASTICACHE REDIS (Cluster Mode)
# High-performance distributed caching
# ============================================
REDIS_HOST=sahayak-redis.xxxxx.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your_elasticache_password
REDIS_TLS_ENABLED=true
REDIS_CLUSTER_MODE=true
REDIS_MAX_RETRIES=5

# Cache Configuration
CACHE_SCHEME_DATA_TTL=86400
CACHE_QUERY_RESPONSE_TTL=7200
CACHE_ELIGIBILITY_TTL=3600
ENABLE_RESPONSE_CACHING=true
ENABLE_SCHEME_CACHING=true

# ============================================
# STORAGE - AWS S3
# ============================================
S3_BUCKET=sahayak-data-bucket-prod
S3_FRONTEND_BUCKET=sahayak-ai-frontend-prod
S3_DATA_BUCKET=sahayak-ai-data-prod
S3_UPLOADS_BUCKET=sahayak-ai-uploads-prod
S3_REGION=ap-south-1
SCHEMES_CSV_KEY=schemes/schemes.csv
SCHEMES_JSON_KEY=schemes/schemes.json

# ============================================
# API GATEWAY & CDN
# ============================================
API_GATEWAY_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod
API_BASE_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod
CLOUDFRONT_DISTRIBUTION_ID=your-distribution-id
CLOUDFRONT_DOMAIN=your-domain.cloudfront.net

# ============================================
# AI PROVIDERS - MULTI-PROVIDER FALLBACK
# ============================================
AI_PROVIDER=router
AI_PROVIDER_PRIMARY_MODEL=router
AI_ROUTING_ENABLED=true
SARVAM_API_KEY=your_sarvam_key_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=your_openai_key_here
AI_RETRY_ATTEMPTS=3
AI_TIMEOUT_MS=45000

# ============================================
# AWS AI SERVICES
# ============================================
BEDROCK_ENABLED=true
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=us-east-1
POLLY_ENABLED=true
TRANSCRIBE_ENABLED=true
VOICE_PROVIDER=aws
AWS_POLLY_VOICE_ID_HI=Aditi
AWS_POLLY_VOICE_ID_EN=Joanna
AWS_POLLY_ENGINE=neural
AWS_TRANSCRIBE_LANGUAGE_CODE_HI=hi-IN
AWS_TRANSCRIBE_LANGUAGE_CODE_EN=en-IN

# ============================================
# PERFORMANCE & SCALING
# ============================================
RATE_LIMIT_PER_MINUTE=300
RATE_LIMIT_PER_HOUR=10000
MAX_MESSAGE_LENGTH=2000
MAX_CONCURRENT_REQUESTS=1000
LAMBDA_MEMORY_SIZE=2048
LAMBDA_TIMEOUT=300
LAMBDA_RESERVED_CONCURRENCY=100

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=info
ENABLE_CLOUDWATCH_LOGS=true
ENABLE_XRAY_TRACING=true
ENABLE_METRICS=true

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_VOICE_INPUT=true
ENABLE_VOICE_OUTPUT=true
ENABLE_ANALYTICS=true

# ============================================
# FRONTEND
# ============================================
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod
NEXT_PUBLIC_ENVIRONMENT=production
