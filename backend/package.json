{
  "name": "@sahayak/backend",
  "version": "1.0.0",
  "description": "Sahayak AI Backend Services",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/local.ts",
    "build": "tsc",
    "start": "node dist/api/index.js",
    "vercel-build": "echo 'No build step needed for Vercel'",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "migrate:up": "ts-node src/db/migrate.ts up",
    "migrate:down": "ts-node src/db/migrate.ts down",
    "seed": "ts-node src/db/seed.ts",
    "deploy": "npm run build && serverless deploy"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.490.0",
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/client-polly": "^3.490.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/client-transcribe": "^3.490.0",
    "@aws-sdk/lib-dynamodb": "^3.490.0",
    "@google/generative-ai": "^0.24.1",
    "@types/aws-lambda": "^8.10.131",
    "@vercel/node": "^5.6.15",
    "aws-lambda": "^1.0.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fast-check": "^3.15.0",
    "groq-sdk": "^0.3.0",
    "ioredis": "^5.3.2",
    "openai": "^6.27.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.131",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "jest": "^30.2.0",
    "serverless": "^3.38.0",
    "serverless-offline": "^13.3.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
