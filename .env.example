# ============================================
# SAHAYAK AI - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================

# Environment
NODE_ENV=development
ENVIRONMENT=development
PORT=3001

# ============================================
# AWS CONFIGURATION (for production deployment)
# ============================================
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================
# DATABASE - DYNAMODB (Production)
# ============================================
DYNAMODB_SCHEMES_TABLE=sahayak-schemes
DYNAMODB_APPLICATIONS_TABLE=sahayak-applications
DYNAMODB_CHAT_SESSIONS_TABLE=sahayak-chat-sessions
DYNAMODB_SERVICE_CENTERS_TABLE=sahayak-service-centers

# ============================================
# DATABASE - RDS POSTGRESQL (Optional)
# ============================================
RDS_HOST=localhost
RDS_PORT=5432
RDS_DATABASE=sahayak
RDS_USER=sahayak_app
RDS_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sahayak
DB_USER=postgres
DB_PASSWORD=
DB_MAX_CONNECTIONS=20
DB_SSL=false

# ============================================
# CACHE - REDIS
# Local: localhost | AWS: ElastiCache endpoint
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false
REDIS_CLUSTER_MODE=false
REDIS_MAX_RETRIES=3

# Cache Settings
CACHE_SCHEME_DATA_TTL=86400
CACHE_QUERY_RESPONSE_TTL=3600
CACHE_ELIGIBILITY_TTL=3600
CACHE_SESSION_TTL=1800
ENABLE_RESPONSE_CACHING=true
ENABLE_SCHEME_CACHING=true
ENABLE_QUERY_CACHING=true

# ============================================
# STORAGE - S3 (Production) / Local (Development)
# ============================================
S3_FRONTEND_BUCKET=sahayak-ai-frontend
S3_DATA_BUCKET=sahayak-ai-data
S3_UPLOADS_BUCKET=sahayak-ai-uploads
S3_REGION=ap-south-1
SCHEMES_CSV_KEY=schemes/schemes.csv
SCHEMES_JSON_KEY=schemes/schemes.json
DATA_PATH=./data

# ============================================
# CDN - CLOUDFRONT (Production)
# ============================================
CLOUDFRONT_DISTRIBUTION_ID=
CLOUDFRONT_DOMAIN=

# ============================================
# API GATEWAY (Production)
# ============================================
API_GATEWAY_URL=
API_GATEWAY_API_KEY=
API_BASE_URL=http://localhost:3001

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=3600
RATE_LIMIT_PER_DAY=50000
MAX_MESSAGE_LENGTH=1000
MAX_CONCURRENT_REQUESTS=100

# ============================================
# AI PROVIDERS - MULTI-PROVIDER SETUP
# Get API keys from respective providers
# ============================================
AI_PROVIDER=router
AI_PROVIDER_PRIMARY_MODEL=router
AI_ROUTING_ENABLED=true

# AI Provider API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
SARVAM_API_KEY=

# AI Performance Settings
AI_RETRY_ATTEMPTS=1
AI_TIMEOUT_MS=30000
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7
AI_CONCURRENT_REQUESTS=10

# ============================================
# AWS AI SERVICES (Production)
# ============================================
BEDROCK_ENABLED=false
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=us-east-1
BEDROCK_MAX_TOKENS=1000
BEDROCK_TEMPERATURE=0.7

# ============================================
# VOICE SERVICES
# Development: web-speech | Production: aws
# ============================================
VOICE_PROVIDER=web-speech
POLLY_ENABLED=false
TRANSCRIBE_ENABLED=false

# Amazon Polly (Text-to-Speech)
AWS_POLLY_VOICE_ID_HI=Aditi
AWS_POLLY_VOICE_ID_EN=Joanna
AWS_POLLY_ENGINE=neural
AWS_POLLY_OUTPUT_FORMAT=mp3
AWS_POLLY_SAMPLE_RATE=24000

# Amazon Transcribe (Speech-to-Text)
AWS_TRANSCRIBE_LANGUAGE_CODE_HI=hi-IN
AWS_TRANSCRIBE_LANGUAGE_CODE_EN=en-IN
AWS_TRANSCRIBE_SAMPLE_RATE=16000

# ============================================
# LAMBDA CONFIGURATION (Production)
# ============================================
LAMBDA_MEMORY_SIZE=1024
LAMBDA_TIMEOUT=30
LAMBDA_RESERVED_CONCURRENCY=10
LAMBDA_PROVISIONED_CONCURRENCY=0

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=debug
ENABLE_CLOUDWATCH_LOGS=false
ENABLE_XRAY_TRACING=false
ENABLE_METRICS=false
METRICS_NAMESPACE=SahayakAI/Development

# ============================================
# SECURITY
# ============================================
ENABLE_CORS=true
CORS_ORIGIN=*
ENABLE_RATE_LIMITING=true
ENABLE_API_KEY_AUTH=false
ENABLE_JWT_AUTH=false
SESSION_SECRET=
JWT_SECRET=

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_VOICE_INPUT=true
ENABLE_VOICE_OUTPUT=true
ENABLE_MULTILINGUAL=true
ENABLE_ANALYTICS=false
ENABLE_ERROR_REPORTING=false

# ============================================
# EXTERNAL SERVICES
# ============================================
MAP_PROVIDER=openstreetmap
GOOGLE_MAPS_API_KEY=

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENVIRONMENT=development

# ============================================
# PERFORMANCE OPTIMIZATION
# ============================================
ENABLE_COMPRESSION=true
ENABLE_HTTP2=false
ENABLE_KEEP_ALIVE=true
CONNECTION_POOL_SIZE=20
REQUEST_TIMEOUT=30000
IDLE_TIMEOUT=60000

# ============================================
# AUTO-SCALING (Production)
# ============================================
AUTO_SCALE_ENABLED=false
MIN_INSTANCES=1
MAX_INSTANCES=10
TARGET_CPU_UTILIZATION=70
TARGET_MEMORY_UTILIZATION=80
SCALE_UP_COOLDOWN=60
SCALE_DOWN_COOLDOWN=300
