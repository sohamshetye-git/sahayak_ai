# Environment
NODE_ENV=development
ENVIRONMENT=development

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB Tables
DYNAMODB_SCHEMES_TABLE=sahayak-schemes
DYNAMODB_APPLICATIONS_TABLE=sahayak-applications
DYNAMODB_CHAT_SESSIONS_TABLE=sahayak-chat-sessions
DYNAMODB_SERVICE_CENTERS_TABLE=sahayak-service-centers

# RDS PostgreSQL (Optional - if using RDS instead of DynamoDB)
RDS_HOST=localhost
RDS_PORT=5432
RDS_DATABASE=sahayak
RDS_USER=sahayak_app
RDS_PASSWORD=

# ElastiCache Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TLS_ENABLED=false
# For AWS ElastiCache, use:
# REDIS_HOST=sahayak-cache.xxxxx.cache.amazonaws.com
# REDIS_PORT=6379
# REDIS_TLS_ENABLED=true

# S3 Buckets
S3_FRONTEND_BUCKET=sahayak-ai-frontend
S3_DATA_BUCKET=sahayak-ai-data
S3_UPLOADS_BUCKET=sahayak-ai-uploads
S3_REGION=ap-south-1
SCHEMES_CSV_KEY=schemes/schemes.csv

# CloudFront
CLOUDFRONT_DISTRIBUTION_ID=
CLOUDFRONT_DOMAIN=

# API Gateway
API_GATEWAY_URL=
API_GATEWAY_API_KEY=

# Amazon Bedrock
BEDROCK_ENABLED=false
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=us-east-1

# Amazon Polly (Text-to-Speech)
POLLY_ENABLED=false
AWS_POLLY_VOICE_ID_HI=Aditi
AWS_POLLY_VOICE_ID_EN=Joanna
AWS_POLLY_ENGINE=neural

# Amazon Transcribe (Speech-to-Text)
TRANSCRIBE_ENABLED=false
AWS_TRANSCRIBE_LANGUAGE_CODE_HI=hi-IN
AWS_TRANSCRIBE_LANGUAGE_CODE_EN=en-IN

# AI Provider Configuration
AI_PROVIDER=gemini
AI_PROVIDER_PRIMARY_MODEL=gemini-pro
AI_PROVIDER_FALLBACK_MODEL=amazon.nova-lite-v1:0
AI_PROVIDER_TERTIARY_MODEL=llama-3.1-8b-instant
AI_PROVIDER_QUATERNARY_MODEL=sarvam-2b
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
SARVAM_API_KEY=
AI_RETRY_ATTEMPTS=1
AI_TIMEOUT_MS=30000

# Voice Provider Configuration
VOICE_PROVIDER=web-speech
AWS_TRANSCRIBE_LANGUAGE_CODE_HI=hi-IN
AWS_TRANSCRIBE_LANGUAGE_CODE_EN=en-IN
AWS_POLLY_VOICE_ID_HI=Aditi
AWS_POLLY_VOICE_ID_EN=Raveena

# Application Configuration
API_BASE_URL=http://localhost:3001
RATE_LIMIT_PER_MINUTE=60
MAX_MESSAGE_LENGTH=1000

# Cache Settings
CACHE_SCHEME_DATA_TTL=86400
CACHE_QUERY_RESPONSE_TTL=3600
CACHE_ELIGIBILITY_TTL=3600
ENABLE_RESPONSE_CACHING=true
ENABLE_SCHEME_CACHING=true

# Feature Flags
ENABLE_VOICE_INPUT=true
ENABLE_VOICE_OUTPUT=true

# Map Provider
MAP_PROVIDER=openstreetmap
GOOGLE_MAPS_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
